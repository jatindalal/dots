background = 010101
background-opacity = 0.95
background-blur=40

cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

theme = Kanagawa Wave
window-height = 24
window-width = 80
window-padding-x = 4
window-padding-y = 4

font-family = Iosevka Nerd Font
font-size = 18
font-thicken = true

cursor-style = bar

term = xterm-256color

confirm-close-surface = false
macos-titlebar-style = tabs
command = /opt/homebrew/bin/fish -c "tmux -u attach -t main 2>/dev/null || tmux -u new -s main"
